# FeintSignal local environment template.
# Copy to .env for local use. NEVER commit .env or real secrets.

# Core local services
FEINTSIGNAL_ENV=local
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8765
FRONTEND_PORT=5173

# Capability gates (all external capabilities stay OFF by default)
ENABLE_LIVE_RESEARCH=false
ENABLE_LLM=false
ENABLE_DISCORD_SEND=false
ENABLE_DISCORD_FANOUT=false
ENABLE_DISCORD_DIGESTS=false
ENABLE_DISCORD_RAW_LOGS=false
DISCORD_MAX_FANOUT_PER_RUN=24

# Optional LLM synthesis (not used while ENABLE_LLM=false).
# Supported LLM_PROVIDER values: anthropic or openai.
LLM_PROVIDER=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-5-mini
# Top N stories enriched per pipeline run (covers the presentation rotation).
LLM_MAX_EVENTS=15
# Events per batched LLM call; smaller chunks avoid request timeouts.
LLM_CHUNK_SIZE=5
LLM_MAX_OUTPUT_TOKENS=8000
LLM_TIMEOUT_SECONDS=90
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Discord webhook-only MVP
# Server ID is optional for webhooks; keep it for the future bot phase.
DISCORD_SERVER_ID=
DISCORD_WEBHOOK_HEARTBEAT=
DISCORD_WEBHOOK_SYSTEM_STATUS=
DISCORD_WEBHOOK_AGENT_RUNS=
DISCORD_WEBHOOK_ERRORS=
DISCORD_WEBHOOK_COST_CONTROL=
DISCORD_WEBHOOK_BREAKING=
DISCORD_WEBHOOK_CRITICAL=
DISCORD_WEBHOOK_DAILY_BRIEF=
DISCORD_WEBHOOK_SITREP=

# Discord bot identity (validated for readiness; outbound delivery still uses webhooks)
DISCORD_BOT_NAME=Watchtower
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=
DISCORD_BOT_TOKEN=

# Future Discord bot channel IDs: FEINTSIGNAL COMMAND
DISCORD_CHANNEL_COMMAND_CENTER=
DISCORD_CHANNEL_WATCHLIST=
DISCORD_CHANNEL_OPERATOR_NOTES=

# Future Discord bot channel IDs: FEINTSIGNAL OPS
DISCORD_CHANNEL_HEARTBEAT_LOG=
DISCORD_CHANNEL_SYSTEM_STATUS=
DISCORD_CHANNEL_AGENT_RUNS=
DISCORD_CHANNEL_ERROR_LOG=
DISCORD_CHANNEL_COST_CONTROL=

# Future Discord bot channel IDs: FEINTSIGNAL ALERTS
DISCORD_CHANNEL_BREAKING_ALERTS=
DISCORD_CHANNEL_CRITICAL_ALERTS=

# Future Discord bot channel IDs: FEINTSIGNAL INTEL
DISCORD_CHANNEL_DAILY_BRIEF=
DISCORD_CHANNEL_SITREP=
DISCORD_CHANNEL_BIAS_FRAMING=

# Future Discord bot channel IDs: FEINTSIGNAL REGIONS
DISCORD_CHANNEL_GLOBAL=
DISCORD_CHANNEL_NORTH_AMERICA=
DISCORD_CHANNEL_LATIN_AMERICA=
DISCORD_CHANNEL_EUROPE=
DISCORD_CHANNEL_MIDDLE_EAST=
DISCORD_CHANNEL_AFRICA=
DISCORD_CHANNEL_ASIA_PACIFIC=

# Future Discord bot channel IDs: FEINTSIGNAL DOMAINS
DISCORD_CHANNEL_CYBER=
DISCORD_CHANNEL_CONFLICT=
DISCORD_CHANNEL_POLITICS=
DISCORD_CHANNEL_ECONOMY=
DISCORD_CHANNEL_ENERGY_SUPPLYCHAIN=
DISCORD_CHANNEL_DISASTERS_HEALTH=
DISCORD_CHANNEL_ORGANIZED_CRIME=
DISCORD_CHANNEL_TERRORISM=
DISCORD_CHANNEL_TECH_AI=

# Future Discord bot channel IDs: FEINTSIGNAL DEV/BOT
DISCORD_CHANNEL_BOT_ERRORS=
DISCORD_CHANNEL_RAW_LOGS=
DISCORD_CHANNEL_DEV_NOTES=

# Safety and automation
ENABLE_SCHEDULER=false
UPDATE_INTERVAL_MINUTES=60
MAX_EVENTS_PER_RUN=50
LOG_LEVEL=INFO

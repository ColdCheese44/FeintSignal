# FeintSignal local environment template.
# Copy to .env for local use. NEVER commit .env or real secrets.

# Core local services
FEINTSIGNAL_ENV=local
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8765
FRONTEND_PORT=5173

# Capability gates (all external capabilities stay OFF by default)
ENABLE_LIVE_RESEARCH=false
ENABLE_LLM=false
ENABLE_DISCORD_SEND=false

# Optional LLM providers (not used while ENABLE_LLM=false)
LLM_PROVIDER=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Discord webhook-only MVP
# Server ID is optional for webhooks; keep it for the future bot phase.
DISCORD_SERVER_ID=
DISCORD_WEBHOOK_HEARTBEAT=
DISCORD_WEBHOOK_SYSTEM_STATUS=
DISCORD_WEBHOOK_AGENT_RUNS=
DISCORD_WEBHOOK_ERRORS=
DISCORD_WEBHOOK_COST_CONTROL=
DISCORD_WEBHOOK_BREAKING=
DISCORD_WEBHOOK_CRITICAL=
DISCORD_WEBHOOK_HUMAN_REVIEW=
DISCORD_WEBHOOK_DAILY_BRIEF=
DISCORD_WEBHOOK_SITREP=

# Future Discord bot identity (not required or used by the webhook MVP)
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=
DISCORD_BOT_TOKEN=

# Future Discord bot channel IDs: command and review
DISCORD_CHANNEL_COMMAND_POST=
DISCORD_CHANNEL_HUMAN_REVIEW=
DISCORD_CHANNEL_WATCHLIST=
DISCORD_CHANNEL_OPERATOR_NOTES=
DISCORD_CHANNEL_MONITORING=
DISCORD_CHANNEL_ESCALATED=
DISCORD_CHANNEL_SOURCE_REVIEW=
DISCORD_CHANNEL_BIAS_FRAMING=
DISCORD_CHANNEL_RESEARCH_QUEUE=

# Future Discord bot channel IDs: regions
DISCORD_CHANNEL_GLOBAL=
DISCORD_CHANNEL_NORTH_AMERICA=
DISCORD_CHANNEL_LATIN_AMERICA=
DISCORD_CHANNEL_EUROPE=
DISCORD_CHANNEL_MIDDLE_EAST=
DISCORD_CHANNEL_AFRICA=
DISCORD_CHANNEL_ASIA_PACIFIC=

# Future Discord bot channel IDs: domains
DISCORD_CHANNEL_CYBER=
DISCORD_CHANNEL_CONFLICT=
DISCORD_CHANNEL_POLITICS=
DISCORD_CHANNEL_ECONOMY=
DISCORD_CHANNEL_ENERGY_SUPPLYCHAIN=
DISCORD_CHANNEL_DISASTERS_HEALTH=
DISCORD_CHANNEL_CRIME_CARTELS=
DISCORD_CHANNEL_TECH_AI=

# Future Discord bot channel IDs: development
DISCORD_CHANNEL_BOT_ERRORS=
DISCORD_CHANNEL_RAW_LOGS=
DISCORD_CHANNEL_DEV_NOTES=

# Safety and automation
REQUIRE_HUMAN_REVIEW_FOR_CRITICAL=true
UPDATE_INTERVAL_MINUTES=60
MAX_EVENTS_PER_RUN=50
LOG_LEVEL=INFO

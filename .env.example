# FeintSignal local environment template.
# Copy to .env for local use. NEVER commit .env or real secrets.

FEINTSIGNAL_ENV=local
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8765
FRONTEND_PORT=5173

# Capability gates — all OFF by default. FeintSignal runs fully on mock data.
ENABLE_LIVE_RESEARCH=false
ENABLE_LLM=false
LLM_PROVIDER=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Discord alerting — sending stays OFF unless explicitly enabled AND a webhook is set.
ENABLE_DISCORD_SEND=false
DISCORD_WEBHOOK_HEARTBEAT=
DISCORD_WEBHOOK_BREAKING=
DISCORD_WEBHOOK_DAILY_BRIEFING=
DISCORD_WEBHOOK_SYSTEM_STATUS=

# Safety
REQUIRE_HUMAN_REVIEW_FOR_CRITICAL=true

# Automation loop
UPDATE_INTERVAL_MINUTES=60
MAX_EVENTS_PER_RUN=50
LOG_LEVEL=INFO
